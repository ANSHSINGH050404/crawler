      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "analytics-pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  content_id,\n  COUNT(*) FILTER (WHERE event_type = 'video_start')::bigint AS video_starts,\n  COUNT(*) FILTER (WHERE event_type = 'video_complete')::bigint AS completes,\n  COUNT(*) AS events\nFROM analytics_events\nWHERE $__timeFilter(received_at)\n  AND content_id IS NOT NULL\nGROUP BY 1\nORDER BY events DESC\nLIMIT 25",
          "refId": "A"
        }
