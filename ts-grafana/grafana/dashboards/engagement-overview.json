          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  event_type,\n  COUNT(*)::bigint AS events\nFROM analytics_events\nWHERE $__timeFilter(received_at)\n  AND event_type IN ('video_start','video_progress','video_complete','video_pause','video_seek')\nGROUP BY 1\nORDER BY 2 DESC",
