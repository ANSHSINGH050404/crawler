PORT=8080
DATABASE_URL=postgres://admin:secret@localhost:5432/analytics
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_KEY=analytics:events

# Comma-separated keys; if empty, ingest auth is disabled (development only)
INGEST_API_KEYS=

# Max events per POST and approximate max JSON body size
MAX_EVENTS_PER_REQUEST=100
MAX_BODY_BYTES=262144

# 0 = disabled. Per IP per minute (requires Redis).
RATE_LIMIT_PER_MINUTE=3000

# CORS: * or comma-separated origins
ALLOWED_ORIGINS=*

# Worker tuning
WORKER_BATCH_SIZE=250
WORKER_BLOCK_SECONDS=2
WORKER_FLUSH_MS=2000

# Optional salt for ip_hash (change in production)
IP_SALT=change-me
